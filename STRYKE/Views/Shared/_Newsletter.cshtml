<div class="newsletter">
    <div class="newsletter__icon">
        <svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
    </div>
    <div class="newsletter__text">
        <h3>Never Miss a Drop</h3>
        <p>Sign up for exclusive offers, early access, and training tips.</p>
    </div>
    <form class="newsletter__form" asp-controller="Newsletter" asp-action="Subscribe" method="post">
        @Html.AntiForgeryToken()
        <input class="newsletter__input" type="email" name="email" placeholder="Enter your email address" required />
        <button type="submit" class="newsletter__submit">Sign Up</button>
    </form>
</div>
