@{
    var controller = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var action = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
    string NavClass(string navController, string navAction = "Index") =>
        controller.Equals(navController, StringComparison.OrdinalIgnoreCase) &&
        action.Equals(navAction, StringComparison.OrdinalIgnoreCase)
            ? "active"
            : "";
}

<nav class="navbar">
    <a asp-controller="Home" asp-action="Index" class="navbar__logo">
        <svg width="20" height="24" viewBox="0 0 20 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M11 0L0 14H9L9 24L20 10H11L11 0Z" fill="#e8001c"/>
        </svg>
        STRYK
    </a>

    <ul class="navbar__nav">
        <li><a asp-controller="Home" asp-action="Index" class="@NavClass("Home")">Home</a></li>
        <li><a asp-controller="Shop" asp-action="Index">Shop</a></li>
        <li><a href="#" class="has-dropdown">Categories</a></li>
        <li><a asp-controller="Men" asp-action="Index">Men</a></li>
        <li><a asp-controller="Women" asp-action="Index">Women</a></li>
        <li><a asp-controller="About" asp-action="Index">About</a></li>
        <li><a asp-controller="Contact" asp-action="Index">Contact</a></li>
    </ul>

    <div class="navbar__actions">
        <button type="button" aria-label="Search">
            <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
        </button>
        <button type="button" aria-label="Account">
            <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        </button>
        <button type="button" aria-label="Cart" style="position:relative">
            <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
            <span class="cart-badge">2</span>
        </button>
    </div>
</nav>

