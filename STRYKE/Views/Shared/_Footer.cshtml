<footer class="footer">
    <div class="footer__top">
        <div class="footer__brand">
            <a asp-controller="Home" asp-action="Index" class="navbar__logo" style="margin-bottom:0">
                <svg width="18" height="22" viewBox="0 0 20 24" fill="none" aria-hidden="true"><path d="M11 0L0 14H9L9 24L20 10H11L11 0Z" fill="#e8001c"/></svg>
                STRYK
            </a>
            <p>Premium sportswear engineered for performance, built for your greatest.</p>
            <div class="footer__socials">
                <a href="#" aria-label="Instagram">ig</a>
                <a href="#" aria-label="Facebook">fb</a>
                <a href="#" aria-label="YouTube">yt</a>
                <a href="#" aria-label="TikTok">tk</a>
            </div>
        </div>

        <div class="footer__col">
            <h5>Shop</h5>
            <ul>
                <li><a asp-controller="Shop" asp-action="Index">All Products</a></li>
                <li><a asp-controller="Men" asp-action="Index">Men</a></li>
                <li><a asp-controller="Women" asp-action="Index">Women</a></li>
                <li><a asp-controller="Accessories" asp-action="Index">Accessories</a></li>
                <li><a asp-controller="Shop" asp-action="NewArrivals">New Arrivals</a></li>
            </ul>
        </div>

        <div class="footer__col">
            <h5>Company</h5>
            <ul>
                <li><a asp-controller="About" asp-action="Index">About Us</a></li>
                <li><a asp-controller="About" asp-action="Technology">Our Technology</a></li>
                <li><a asp-controller="About" asp-action="Sustainability">Sustainability</a></li>
                <li><a asp-controller="About" asp-action="Careers">Careers</a></li>
                <li><a asp-controller="Contact" asp-action="Index">Contact</a></li>
            </ul>
        </div>

        <div class="footer__col">
            <h5>Help</h5>
            <ul>
                <li><a asp-controller="Help" asp-action="Shipping">Shipping &amp; Delivery</a></li>
                <li><a asp-controller="Help" asp-action="Returns">Returns &amp; Exchanges</a></li>
                <li><a asp-controller="Help" asp-action="SizeGuide">Size Guide</a></li>
                <li><a asp-controller="Help" asp-action="FAQ">FAQ</a></li>
                <li><a asp-controller="Help" asp-action="TrackOrder">Track Order</a></li>
            </ul>
        </div>

        <div class="footer__col">
            <h5>Contact</h5>
            <address>
                Email: <a href="mailto:support@stryk.com">support@stryk.com</a><br />
                Phone: (888) 123-STRYK<br />
                Mon – Fri: 9AM – 6PM EST
            </address>
            <div class="footer__payments">
                <span class="payment-badge">VISA</span>
                <span class="payment-badge">MC</span>
                <span class="payment-badge">AMEX</span>
                <span class="payment-badge">PayPal</span>
                <span class="payment-badge">Apple Pay</span>
            </div>
        </div>
    </div>

    <div class="footer__bottom">
        <p>&copy; @DateTime.Now.Year STRYK. All rights reserved.</p>
        <div class="footer__bottom-links">
            <a asp-controller="Home" asp-action="Privacy">Privacy Policy</a>
            <a asp-controller="Legal" asp-action="Terms">Terms of Service</a>
            <a asp-controller="Legal" asp-action="Accessibility">Accessibility</a>
        </div>
    </div>
</footer>
